# ══════════════════════════════════════════════════
# TARTARUS — Environment Variables
# Copy to .env: cp .env.example .env
# ══════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────
POSTGRES_USER=tartarus
POSTGRES_PASSWORD=tartarus_dev_2026
POSTGRES_DB=tartarus
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ ──────────────────────────────────────
RABBITMQ_URI=amqp://guest:guest@broker:5672/
RABBITMQ_MANAGEMENT_PORT=15672

# ── Beelzebub ─────────────────────────────────────
BEELZEBUB_IMAGE=m4r10/beelzebub:latest

# ── LLM Keys (optional — Fase 1+) ────────────────
OPEN_AI_SECRET_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ── Engine ────────────────────────────────────────
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8000
ENGINE_LOG_LEVEL=info

# ── Dev Ports (Mac M4 — avoid :22, :80, :8000) ───
DEV_SSH_PORT=2222
DEV_HTTP_PORT=8880
DEV_HTTPS_PORT=8443
DEV_ENGINE_PORT=9000
DEV_UI_PORT=8888
DEV_ADMINER_PORT=9080
